# =============================================================================
# Customer 360 Platform - consolidated configuration
#
# Copy this file to `.env` (same directory as docker-compose.yml) and adjust
# values for your environment. `.env` is gitignored and is used TWO ways by
# docker-compose.yml:
#   1. ${VAR} substitution inside docker-compose.yml itself (e.g. seeding the
#      official postgres/redis images' bootstrap env vars).
#   2. Passed into every container via `env_file:` so customer360-api and
#      identity-resolution-service (CIR) read it exactly like they do for
#      non-Docker local dev (pydantic-settings / python-dotenv).
#
# NOTE: DB_HOST / REDIS_HOST below are irrelevant *inside* docker-compose --
# docker-compose.yml always overrides them to the in-network service names
# (`postgres` / `redis`) for the api/cir/cir-demo-seed containers. They only
# matter if you run customer360-api or identity-resolution-service directly
# on the host (./start.sh, ./run-demo.sh) against the dockerized Postgres/
# Redis (in which case `localhost` + the published host ports is correct).
# =============================================================================

# ----- PostgreSQL --------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_postgres_password
DB_NAME=customer360
DB_SCHEMA=customer360

# Optional: change the host-published Postgres port (container always listens
# on 5432 internally).
POSTGRES_HOST_PORT=5432

# ----- Redis (customer360-api response cache) -----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me_redis_password

# Optional: change the host-published Redis port.
REDIS_HOST_PORT=6379

# Toggle the whole caching layer on/off + default TTL for cached responses.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60

# ----- customer360-api: SQLAlchemy connection pool -------------------------
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
DB_ECHO_SQL=false

# ----- customer360-api: FastAPI / uvicorn ----------------------------------
API_DEFAULT_PAGE_SIZE=100
API_MAX_PAGE_SIZE=1000
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_RELOAD=false

# Optional: change the host-published API port.
API_HOST_PORT=8000

# ----- identity-resolution-service (CIR) -----------------------------------
CIR_BATCH_SIZE=5000
# How often (seconds) the containerized CIR worker polls for new/unresolved
# raw profiles. Only used by identity-resolution-service/worker.py.
CIR_POLL_INTERVAL_SECONDS=30

GOOGLE_GENAI_API_KEY=YOUR_GOOGLE_GENAI_API_KEY
# GOOGLE_GENAI_MODEL=gemini-3.5-flash
